# LLM provider for main.py: local, external, or yandex
LLM_PROVIDER=local

# Local OpenAI-compatible LLM, for example LM Studio
LOCAL_LLM_URL=http://127.0.0.1:1234/v1
LOCAL_MODEL=qwen/qwen3.5-9b
LOCAL_API_KEY=lm-studio

# External OpenAI-compatible LLM
EXTERNAL_LLM_URL=https://api.openai.com/v1
EXTERNAL_LLM_MODEL=gpt-4o-mini
EXTERNAL_LLM_API_KEY=

# OpenAI-compatible aliases used by some providers/tools
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
OPENAI_API_KEY=

# Yandex AI Studio, used only when LLM_PROVIDER=yandex
YANDEX_LLM_URL=https://ai.api.cloud.yandex.net/v1
YANDEX_CLOUD_FOLDER=
YANDEX_CLOUD_API_KEY=
YANDEX_CLOUD_MODEL=qwen3.6-35b-a3b/latest

# Shared LLM generation settings
LLM_TEMPERATURE=0.1
LLM_MAX_TOKENS=10000
RAG_LLM_TIMEOUT=80
RAG_MAX_TOKENS=1200
RAG_CONTEXT_CHUNKS=4
RAG_CHUNK_CHARS=700

# Embeddings for ChromaDB: sentence-transformers, openai-compatible, or hashing
EMBEDDING_BACKEND=sentence-transformers
EMBEDDING_MODEL=models/bge-m3
EMBEDDING_LOCAL_ONLY=1
EMBEDDING_DEVICE=cpu
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DIM=384
EMBEDDING_BASE_URL=http://127.0.0.1:1234/v1
EMBEDDING_API_KEY=lm-studio
EMBEDDING_TIMEOUT=60

# Index and retrieval settings
COLLECTION_NAME=metallurgy
DATA_DIR=data
TANTIVY_INDEX_DIR=tantivy_index
CHROMA_DIR=chroma_db
RETRIEVAL_TOP_K=10
MAX_SEARCH_ITER=10
